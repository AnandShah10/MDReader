{
  "name": "mdreader",
  "displayName": "MD Reader",
  "description": "A professional Markdown previewer extension for Visual Studio Code, providing a customizable webview panel to render Markdown files with enhanced styling.",
  "version": "0.0.2",
  "publisher": "AnandShah",
  "repository": {
    "type": "git",
    "url": "https://github.com/AnandShah10/MDReader.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onCommand:mdreader.preview"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mdreader.preview",
        "title": "MD Reader: Preview Active File"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/marked": "^4.0.0",
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "marked": "^12.0.0"
  },
  "bugs": {
    "url": "https://github.com/AnandShah10/MDReader/issues"
  },
  "homepage": "https://github.com/AnandShah10/MDReader#readme"
}